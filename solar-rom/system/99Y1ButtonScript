#!/system/bin/sh
# Solar Y1 long-hold gestures. The init.d entry backgrounds one supervisor;
# steady state is one shell plus one blocking getevent process.

PIDFILE=/data/data/.solar_button_reader.pid
MAX_HOLD=10
GETEVENT_BIN=${GETEVENT_BIN:-getevent}

find_key_device() {
    for name_file in /sys/class/input/event*/device/name; do
        [ -r "$name_file" ] || continue
        IFS= read -r device_name <"$name_file"
        if [ "$device_name" = "mtk-tpd-kpd" ]; then
            event_name=${name_file#/sys/class/input/}
            event_name=${event_name%%/*}
            printf '/dev/input/%s\n' "$event_name"
            return 0
        fi
    done
    return 1
}

screen_is_on() {
    if [ -n "${SOLAR_BUTTON_TEST_LOG:-}" ]; then
        [ "${SOLAR_BUTTON_TEST_SCREEN_ON:-1}" = "1" ]
        return
    fi
    power_state=$(dumpsys power 2>/dev/null)
    case "$power_state" in
        *mScreenOn=true*) return 0 ;;
        *) return 1 ;;
    esac
}

restart_rockbox() {
    if [ -n "${SOLAR_BUTTON_TEST_LOG:-}" ]; then
        echo restart >>"$SOLAR_BUTTON_TEST_LOG"
        return
    fi
    pm list packages -e 2>/dev/null | grep -q '^package:org.rockbox$' || return
    am force-stop org.rockbox
    am start -n org.rockbox/.RockboxActivity
}

launcher_handoff() {
    if [ -n "${SOLAR_BUTTON_TEST_LOG:-}" ]; then
        echo handoff >>"$SOLAR_BUTTON_TEST_LOG"
        return
    fi
    if pm list packages -d 2>/dev/null | grep -q '^package:com.solar.launcher$'; then
        sh /data/data/switch-to-stock.sh
    elif pm list packages -d 2>/dev/null | grep -q '^package:org.rockbox$'; then
        sh /data/data/switch-to-stock.sh --rockbox
    fi
}

read_events() {
    device="$1"
    left_down=0
    right_down=0
    back_down=0
    play_down=0
    restart_start=0
    handoff_start=0

    "$GETEVENT_BIN" -t "$device" | while IFS=' ' read -r f1 f2 f3 f4 f5 f6; do
        # API 17 toolbox emits either:
        # [ seconds] type code value
        # [ seconds] /dev/input/eventN: type code value
        if [ "${f3:-}" = "$device:" ]; then
            type_hex=$f4
            code_hex=$f5
            value_hex=$f6
        else
            type_hex=$f3
            code_hex=$f4
            value_hex=$f5
        fi
        [ -n "${value_hex:-}" ] || continue
        [ "$type_hex" = "0001" ] || continue

        code=$((0x$code_hex))
        value=$((0x$value_hex))
        # Repeat events must not reset a chord.
        [ "$value" -eq 2 ] && continue
        [ "$value" -eq 0 ] || [ "$value" -eq 1 ] || continue

        timestamp=${f2%]}
        seconds=${timestamp%%.*}
        case "$code" in
            105) left_down=$value ;;
            106) right_down=$value ;;
            158) back_down=$value ;;
            164) play_down=$value ;;
            *) continue ;;
        esac

        if [ "$left_down" -eq 1 ] && [ "$right_down" -eq 1 ]; then
            [ "$restart_start" -ne 0 ] || restart_start=$seconds
        elif [ "$restart_start" -ne 0 ]; then
            held=$((seconds - restart_start))
            if [ "$held" -ge "$MAX_HOLD" ] && screen_is_on; then
                restart_rockbox
            fi
            restart_start=0
        fi

        if [ "$back_down" -eq 1 ] && [ "$play_down" -eq 1 ]; then
            [ "$handoff_start" -ne 0 ] || handoff_start=$seconds
        elif [ "$handoff_start" -ne 0 ]; then
            held=$((seconds - handoff_start))
            if [ "$held" -ge "$MAX_HOLD" ] && screen_is_on; then
                launcher_handoff
            fi
            handoff_start=0
        fi
    done
}

daemon_main() {
    if [ -f "$PIDFILE" ]; then
        oldpid=$(cat "$PIDFILE" 2>/dev/null)
        if [ -n "$oldpid" ] && kill -0 "$oldpid" 2>/dev/null; then
            exit 0
        fi
    fi
    echo $$ >"$PIDFILE"
    trap 'rm -f "$PIDFILE"' 0 1 2 15

    while [ "$(getprop sys.boot_completed)" != "1" ]; do
        sleep 1
    done
    settings put system sound_effects_enabled 0

    while true; do
        DEVICE=$(find_key_device)
        if [ -n "$DEVICE" ] && [ -r "$DEVICE" ]; then
            read_events "$DEVICE"
        fi
        sleep 1
    done
}

case "${1:-}" in
    --daemon)
        daemon_main
        ;;
    --test-reader)
        read_events "${2:-/dev/input/test}"
        ;;
    *)
        sh "$0" --daemon </dev/null >/dev/null 2>&1 &
        ;;
esac

exit 0
